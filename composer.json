{
    "name": "nicxonsolutions/google-reviews",
    "description": "Laravel Google Reviews widget powered by Google Business Profile OAuth, with Blade, Livewire, Vue, React, and web component starters.",
    "type": "library",
    "license": "GPL-2.0-or-later",
    "homepage": "https://github.com/robertnicjoo/google-reviews",
    "authors": [
        {
            "name": "PT. Nicxon International Solutions",
            "email": "dev@nicxonsolutions.com",
            "homepage": "https://nicxonsolutions.com"
        },
        {
            "name": "Robert Nicjoo",
            "homepage": "https://github.com/robertnicjoo"
        }
    ],
    "support": {
        "issues": "https://github.com/robertnicjoo/google-reviews/issues",
        "source": "https://github.com/robertnicjoo/google-reviews"
    },
    "autoload": {
        "psr-4": {
            "Nicxonsolutions\\GoogleReviews\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Nicxonsolutions\\GoogleReviews\\GoogleReviewsServiceProvider"
            ],
            "aliases": {
                "GoogleReviews": "Nicxonsolutions\\GoogleReviews\\Facades\\GoogleReviews"
            }
        }
    },
    "require": {
        "php": "^8.2",
        "illuminate/cache": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/contracts": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/http": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/routing": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/support": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/view": "^10.0|^11.0|^12.0|^13.0"
    },
    "suggest": {
        "livewire/livewire": "Required only when using the packaged Livewire widget."
    },
    "require-dev": {
        "orchestra/testbench": "^8.0|^9.0|^10.0",
        "phpunit/phpunit": "^10.0|^11.0|^12.0"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
